{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "node",

    "resolveJsonModule": true,

    "types": ["node"],

    "lib": ["ES2021"],

    "typeRoots": [
      "./node_modules/@types"
    ]
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist"]
}