{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "types": ["node"],

    "lib": ["ES2021"],

    "typeRoots": ["./node_modules/@types"]
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}